# Request
uint8 camera_id          # 0 = all cameras, 1,2,3... = specific camera
uint32 interval_seconds # 0.1 = 10Hz, 0.05 = 20Hz, 0.033 = 30Hz
uint16 total_images      # 0 = capture forever, N = capture N images
---
# Response
bool success
string message
uint16 sequence_start    # Starting sequence number
